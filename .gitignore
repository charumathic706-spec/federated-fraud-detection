# =============================================================================
# .gitignore — Blockchain-Based Dynamic Trust Modeling
# Federated Fraud Detection (Flower + PyTorch + Hyperledger Fabric)
# =============================================================================


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
build/
dist/
eggs/
*.egg-info/
*.egg
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# ── Jupyter / IPython ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ── Datasets  (large CSVs — use DVC or download instructions instead) ─────────
data/*.csv
data/*.parquet
data/*.feather
data/*.h5
data/*.hdf5
data/*.pkl
data/*.pickle
data/*.npz
data/*.npy

# ── Partition cache (auto-generated by main.py, never commit) ─────────────────
logs/.partition_cache.npz
*/.partition_cache.npz

# ── Training logs & generated outputs ────────────────────────────────────────
# Commit the schema / example logs if you want, but not gigantic run outputs.
logs/
logs_split2/
governance_output/
*.log

# ── Model checkpoints & weights ───────────────────────────────────────────────
*.pth
*.pt
*.ckpt
checkpoints/
saved_models/

# ── Plots & images (auto-generated; re-run to reproduce) ─────────────────────
# Remove these two lines if you want to commit example plots to the repo.
*.png
*.pdf

# ── Hyperledger Fabric artefacts ──────────────────────────────────────────────
crypto-config/
channel-artifacts/
*.block
*.tx
fabric-ca-client-config.yaml
wallets/
connection-*.json

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.crt
*.p12
secrets.json
config_private.yaml

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
$RECYCLE.BIN/

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── MyPy / type checking ──────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Ray (used by Flower simulation on Linux/Colab) ────────────────────────────
/tmp/ray/
ray_results/